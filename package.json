{
  "name": "mubashir-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Personal academic and technology portfolio for Dr. Mubashir Hussain",
  "author": "Mubashir Hussain <mubashir.hussain@live.com>",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm pagefind",
    "build:no-search": "next build",
    "pagefind": "pagefind --site out --output-subdir _pagefind",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preflight": "tsx scripts/preflight.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,mdx,json,css}\"",
    "studio:dev": "cd studio && pnpm dev",
    "studio:build": "cd studio && pnpm build",
    "studio:deploy": "cd studio && pnpm deploy"
  },
  "dependencies": {
    "@sanity/client": "^6.22.0",
    "@sanity/image-url": "^1.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "16.2.6",
    "next-themes": "^0.4.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.6",
    "@tailwindcss/typography": "^0.5.15",
    "@types/mdx": "^2.0.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "pagefind": "^1.3.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "unrs-resolver", "esbuild"]
  }
}
