# Sanity ─ create the project at https://sanity.io and run `pnpm sanity init` inside ./studio
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01

# Read-only token for build-time fetches (Settings → API → Tokens, Viewer role)
SANITY_READ_TOKEN=

# Public site URL (used for canonical URLs, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://mubashirhussain.com

# Formspree endpoint for the contact form
NEXT_PUBLIC_FORMSPREE_ID=

# Optional: Cloudflare Turnstile spam protection (free 10k req/mo)
# https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: Plausible analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
